[run]
source =
    rtls
# Needed for Python 3.11 and lower
disable_warnings = no-sysmon

[paths]
source =
    src/rtls
    */rtls
    *\rtls

[report]
exclude_lines =
    except ModuleNotFoundError:
    except ImportError:
    pass
    import
    raise NotImplementedError
    .* # Platform-specific.*
    .*:.* # Python \d.*
    .* # Abstract
    .* # Defensive:
    if (?:typing.)?TYPE_CHECKING:
    ^\s*?\.\.\.\s*$
